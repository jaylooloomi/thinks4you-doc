# Root .gitignore for thinks4you-doc

# Node dependencies
node_modules/
**/node_modules/

# Build outputs
dist/
build/
out/

# Environment files
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE / Editor
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates

# Test coverage
coverage/

# Temporary
tmp/
temp/

# Large reference artifacts (optional)
docx-editor/reference/ecma-376/*.zip
docx-editor/reference/ecma-376/*.pdf

# Merged from docx-editor/.gitignore
/*.png
.claude/settings.local.json
.claude/CLAUDE.local.md
.claude/worktrees/
*.swp
*.swo
playwright-report/
test-results/
.ralph/
screenshots/

# Examples framework artifacts (from docx-editor)
examples/*/node_modules/
examples/plugins/*/node_modules/
examples/*/.next/
examples/*/.astro/
examples/*/bun.lockb
examples/*/package-lock.json
examples/plugins/*/bun.lockb
examples/plugins/*/package-lock.json

# Keep lockfiles tracked by default (uncomment if you want to ignore)
# package-lock.json
# yarn.lock
# bun.lock
